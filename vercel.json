{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "if [ \"$VERCEL_ENV\" = \"production\" ]; then exit 1; else exit 0; fi",
  "crons": [
    {
      "path": "/api/cron/publish-scheduled",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/scan-news",
      "schedule": "0 13 * * 1-6"
    },
    {
      "path": "/api/cron/social-post",
      "schedule": "0 17 * * *"
    }
  ]
}
